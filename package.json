{
  "name": "ai-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "bin": {
    "ai-sync": "apps/sync/bin/sync.js",
    "ai-workspace": "apps/workspace/bin/workspace.js"
  },
  "scripts": {
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build",
    "start": "nx run board:start",
    "sync": "node apps/sync/bin/sync.js",
    "wk": "node apps/workspace/bin/workspace.js --config repos.json --workspace wk",
    "board:build": "nx run board:build",
    "test:board": "nx run board:test",
    "publish:verdaccio": "npm publish --workspace @ai-sync/git --workspace @ai-sync/renderers --workspace @ai-sync/config --workspace @ai-sync/skill-sync --workspace @ai-sync/workspace-bootstrap --registry http://localhost:4873"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nx/eslint": "^23.1.0",
    "@nx/eslint-plugin": "^23.1.0",
    "@nx/js": "23.1.0",
    "@nx/vite": "23.1.0",
    "@nx/vitest": "23.1.0",
    "@nx/vue": "^23.1.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.16.1",
    "globals": "^17.7.0",
    "jsdom": "^27.1.0",
    "nx": "^23.1.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  }
}
