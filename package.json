{
  "name": "ai-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ai-sync": "bin/sync.js",
    "ai-workspace": "bin/workspace.js"
  },
  "scripts": {
    "lint": "eslint src bin test eslint.config.js",
    "prestart": "npm run board:build",
    "start": "node apps/board/server.js",
    "sync": "node bin/sync.js",
    "wk": "node bin/workspace.js --config repos.json --workspace wk",
    "board:build": "pnpm --dir apps/board install && pnpm --dir apps/board build",
    "test": "node --test --experimental-test-coverage --test-coverage-include=\"src/**/*.js\" --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=100 'test/**/*.test.js'",
    "test:board": "pnpm --dir apps/board test"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.7.0"
  }
}
