{
  "name": "@ai-sync/board",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "nx": {
    "tags": ["scope:board", "type:app"],
    "targets": {
      "start": {
        "executor": "nx:run-commands",
        "dependsOn": ["build"],
        "options": { "command": "node apps/board/server.js" }
      },
      "test-server": {
        "executor": "nx:run-commands",
        "options": { "command": "node --test apps/board/server.test.js" }
      },
      "test": {
        "dependsOn": ["test-server"]
      }
    }
  }
}
